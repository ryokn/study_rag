MLFLOW_TRACKING_URI=sqlite:///mlruns.db
CHROMA_PERSIST_DIR=./chroma_db

# ============================================================
# LLMプロバイダー設定: gemini / azure_openai / ollama のいずれかを選択
# ============================================================
LLM_PROVIDER=gemini

# --- Gemini（LLM_PROVIDER=gemini の場合） ---
GOOGLE_API_KEY=your_gemini_api_key
LLM_MODEL=gemini-2.5-flash
EMBEDDING_MODEL=gemini-embedding-001

# --- Azure OpenAI（LLM_PROVIDER=azure_openai の場合） ---
# AZURE_OPENAI_API_KEY=your_azure_openai_api_key
# AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/
# AZURE_OPENAI_API_VERSION=2024-02-01
# LLM_MODEL=gpt-4o                              # チャット用デプロイメント名
# AZURE_OPENAI_EMBEDDING_DEPLOYMENT=text-embedding-3-small  # Embedding用デプロイメント名

# --- Ollama（LLM_PROVIDER=ollama の場合） ---
# LLM_MODEL=gemma4:e2b                   # チャット用モデル（ollama pull gemma4:e2b）
# OLLAMA_EMBEDDING_MODEL=nomic-embed-text # Embedding用モデル（ollama pull nomic-embed-text）

# ============================================================
# PDFローダー設定
# ============================================================
# pypdf      : デフォルト。シンプルなテキスト抽出
# pymupdf4llm: 表・図を含むPDFを高精度にMarkdown変換（要 pip install pymupdf4llm）
PDF_LOADER=pypdf
# チャンクログの出力先（空文字にすると出力しない）
CHUNK_LOG_DIR=./logs

# ============================================================
# レート制限設定（Gemini無料枠の場合）
# ============================================================
EMBED_BATCH_SIZE=500
EMBED_BATCH_INTERVAL=0
# LLM生成のリクエスト間隔（秒）従量課金プランはRPM上限が高いため2秒で十分
LLM_REQUEST_INTERVAL=2
